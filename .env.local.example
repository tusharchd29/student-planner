NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Needed for calendar sync to refresh Google's access token server-side.
# Same values used when creating the OAuth client in Google Cloud Console.
client_id=
client_secret=

# Needed for Quick Add task parsing and missed-task re-slotting.
GROQ_API_KEY=

# Needed to encrypt Google OAuth tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=
