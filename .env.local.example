NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Needed for calendar sync to refresh Google's access token server-side.
# Same values used when creating the OAuth client in Google Cloud Console.
client_id=
client_secret=

# Needed for Quick Add task parsing and missed-task re-slotting.
GROQ_API_KEY=

# Needed to encrypt Google OAuth tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Optional. Without this, account deletion still removes all of a user's
# data, but can't close the underlying Supabase Auth login itself. Get
# this from Supabase Dashboard -> Project Settings -> API -> service_role
# key. Keep this SECRET — it bypasses RLS entirely. Never expose it
# client-side (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=
